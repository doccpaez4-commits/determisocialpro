rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /trabajos/{document} {
      // Permit LIST queries where userId matches the authenticated user
      allow list: if request.auth != null;
      
      // Permit GET (single document read) only for the document's owner
      allow get: if request.auth != null && request.auth.uid == resource.data.userId;

      // Create: user must set their own UID
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      
      // Update: must be owner and keep being owner
      allow update: if request.auth != null && request.auth.uid == resource.data.userId && request.auth.uid == request.resource.data.userId;
      
      // Delete: only the owner can delete
      allow delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }
  }
}
