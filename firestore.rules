rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /trabajos/{document} {
      // Regla de lectura: Un usuario solo puede leer los documentos donde él sea el dueño
      allow read: if request.auth != null && request.auth.uid == resource.data.userId;
      
      // Regla de escritura: Un usuario solo puede crear o modificar documentos 
      // si el campo userId del payload coincide con su propio UID
      allow write: if request.auth != null && request.auth.uid == request.resource.data.userId;
    }
  }
}
